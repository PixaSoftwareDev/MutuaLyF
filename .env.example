# ─── Groq ─────────────────────────────────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL_FAST=llama-3.3-70b-versatile
GROQ_MODEL_REASONING=meta-llama/llama-4-scout-17b-16e-instruct

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=platform
POSTGRES_USER=platform_user
POSTGRES_PASSWORD=changeme

# ─── Neo4j ────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# ─── Qdrant ───────────────────────────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# ─── Redis (3 bases separadas) ────────────────────────────────────────────────
# DB 0: Celery broker — jobs en vuelo; pérdida ante restart
# DB 1: cache de respuestas (TTL 1h, pérdida aceptable)
# DB 2: rate limiting por tenant (efímero, pérdida aceptable)
REDIS_URL_BROKER=redis://redis:6379/0
REDIS_URL_CACHE=redis://redis:6379/1
REDIS_URL_RATELIMIT=redis://redis:6379/2

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change_me_in_production_min_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=30
JWT_WIDGET_EXPIRE_DAYS=90

# ─── App ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:3000
BASE_DOMAIN=localhost

# ─── Timeouts (ms) — ver tabla en CLAUDE.md ───────────────────────────────────
REDIS_TIMEOUT_MS=20
CLASSIFIER_TIMEOUT_MS=80
NLU_TIMEOUT_MS=200
ORCHESTRATOR_TIMEOUT_MS=50
DB_TIMEOUT_MS=500
RERANKER_TIMEOUT_MS=300
LLM_FAST_TIMEOUT_MS=1500
LLM_REASONING_TIMEOUT_MS=7000
NEO4J_TIMEOUT_MS=500

# ─── Chunking ─────────────────────────────────────────────────────────────────
CHUNK_SIZE_TOKENS=512
CHUNK_OVERLAP_TOKENS=64

# ─── Modelos locales ──────────────────────────────────────────────────────────
EMBEDDING_MODEL=intfloat/multilingual-e5-large
RERANKER_MODEL=BAAI/bge-reranker-large
NLU_MODEL=urchade/gliner_large-v2.1

# ─── Cache ────────────────────────────────────────────────────────────────────
CACHE_TTL_SECONDS=3600

# ─── Intent classifier ────────────────────────────────────────────────────────
INTENT_CONFIDENCE_HIGH=0.95
INTENT_CONFIDENCE_MID=0.70
INTENT_AUTO_LEARN_CAP=0.30
INTENT_CLUSTER_MIN_SIZE=15
INTENT_CLUSTER_DISMISS_DAYS=60

# ─── Email ────────────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@example.com

# ─── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# ─── Observabilidad ───────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=changeme_in_production
