# ============================================================================
# .env.example — copiar a .env y completar todos los valores.
# NUNCA commitear .env real.
#
# En produccion (ENVIRONMENT=production), el backend valida al startup que
# los secrets NO esten en defaults de dev y aborta si encuentra alguno.
# Ver _assert_production_secrets_safe() en backend/core/config.py.
# ============================================================================

# ── App ─────────────────────────────────────────────────────────────────────
ENVIRONMENT=development                  # development | staging | production
LOG_LEVEL=INFO
BASE_DOMAIN=localhost
ALLOWED_ORIGINS=http://localhost:3000    # CSV de origenes permitidos por CORS (sin '*' en prod)
# Query rewriter (reescritura LLM de la consulta antes de buscar). A/B 2026-06:
# agregaba ~225ms de media y ~1s en p95 por una llamada Groq extra, sin mejorar
# la calidad (19 vs 18 pass /20). Desactivado en prod para bajar latencia bajo
# carga. Reactivar (true) solo si se justifica con datos.
QUERY_REWRITING_ENABLED=false

# ── Postgres ────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=platform
POSTGRES_USER=platform_user
POSTGRES_PASSWORD=                       # openssl rand -base64 32

# ── Neo4j ───────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=                          # openssl rand -base64 32

# ── Qdrant ──────────────────────────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# ── MinIO (object storage) ──────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=minioadmin               # cambiar en prod
MINIO_ROOT_PASSWORD=                     # openssl rand -base64 32
MINIO_BUCKET=documents
MINIO_SECURE=false

# ── Redis (3 DBs: broker, cache, ratelimit) ─────────────────────────────────
REDIS_URL_BROKER=redis://redis:6379/0
REDIS_URL_CACHE=redis://redis:6379/1
REDIS_URL_RATELIMIT=redis://redis:6379/2

# ── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=                          # openssl rand -hex 64 (min 32 chars)
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=30
JWT_WIDGET_EXPIRE_DAYS=90

# Brute-force protection en /auth/login
LOGIN_MAX_FAILS=10
LOGIN_LOCKOUT_WINDOW_S=600

# ── Groq LLM (modelo principal) ─────────────────────────────────────────────
GROQ_API_KEY=                            # https://console.groq.com
GROQ_MODEL_FAST=llama-3.3-70b-versatile
GROQ_MODEL_REASONING=meta-llama/llama-4-scout-17b-16e-instruct

# ── OpenAI (embeddings + fallback) ──────────────────────────────────────────
OPENAI_API_KEY=
# IMPORTANTE: este es el modelo con el que está indexada la KB (forzado a
# dimensions=1024, compat Qdrant). Cambiarlo OBLIGA a re-embeddear toda la KB del
# tenant — los vectores de modelos distintos no son comparables. No usar 3-large.
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Reranker / Inferencia ───────────────────────────────────────────────────
# Provider del reranker:
#   local → corre bge-reranker en la CPU del backend. Simple, pero compite por CPU
#           y timeoutea bajo carga → scoring inconsistente. OK para dev.
#   tei   → container dedicado text-embeddings-inference (Rust). Rápido (~120ms vs
#           ~2.5s), consistente y no bloquea el backend. RECOMENDADO en PRODUCCIÓN.
#           Requiere el servicio 'tei-reranker' levantado (ver docker-compose.yml +
#           OPERACIONES.md §12). El modelo (bge-reranker-base) lo descarga tei-model-init.
RERANKER_PROVIDER=tei

# ── pgAdmin / Portainer (paneles admin, solo loopback) ──────────────────────
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=                # openssl rand -base64 24

# ── Observability ───────────────────────────────────────────────────────────
GRAFANA_PASSWORD=                        # openssl rand -base64 24
OTEL_ENABLED=false                       # activar para Jaeger tracing
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
OTEL_SAMPLE_RATIO=0.1                    # 0.1 = 10% requests trazados. Full sampling
                                         # agrega ~10-15ms al RAG; 10% → ~1-2ms amortizado
                                         # y sigue capturando cola larga >2s.

# ── Email (onboarding + restablecer contraseña) ─────────────────────────────
# Con Resend: SMTP_HOST=smtp.resend.com · SMTP_USER=resend · SMTP_PASSWORD=<API key>
# EMAIL_FROM debe ser un dominio verificado en el proveedor (ej. noreply@mail.tudominio.com)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=

# URL pública del frontend — base de los enlaces de email (reset de contraseña, etc.)
# Sin barra final. Ej: https://intellix.com.ar
APP_BASE_URL=
