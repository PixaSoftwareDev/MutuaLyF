{
  "title": "IA Platform — Overview",
  "uid": "ia-platform-overview",
  "tags": ["ia", "platform"],
  "timezone": "browser",
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Queries por minuto",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [{
        "expr": "rate(ia_queries_total[1m]) * 60",
        "legendFormat": "{{tenant_id}} / {{complexity}}",
        "datasource": "Prometheus"
      }]
    },
    {
      "id": 2,
      "title": "Latencia p50 / p95 / p99 (ms)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(ia_query_duration_ms_bucket[5m]))",
          "legendFormat": "p50",
          "datasource": "Prometheus"
        },
        {
          "expr": "histogram_quantile(0.95, rate(ia_query_duration_ms_bucket[5m]))",
          "legendFormat": "p95",
          "datasource": "Prometheus"
        },
        {
          "expr": "histogram_quantile(0.99, rate(ia_query_duration_ms_bucket[5m]))",
          "legendFormat": "p99",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 3,
      "title": "Cache hit rate (%)",
      "type": "gauge",
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 8},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "minVizValue": 0, "maxVizValue": 100},
      "targets": [{
        "expr": "rate(ia_cache_hits_total[5m]) / rate(ia_queries_total[5m]) * 100",
        "legendFormat": "Cache hit %",
        "datasource": "Prometheus"
      }]
    },
    {
      "id": 4,
      "title": "Groq — requests por modelo",
      "type": "piechart",
      "gridPos": {"h": 6, "w": 6, "x": 6, "y": 8},
      "targets": [{
        "expr": "increase(ia_groq_requests_total[1h])",
        "legendFormat": "{{model}} / {{status}}",
        "datasource": "Prometheus"
      }]
    },
    {
      "id": 5,
      "title": "Quality Gate — distribución",
      "type": "piechart",
      "gridPos": {"h": 6, "w": 6, "x": 12, "y": 8},
      "targets": [{
        "expr": "increase(ia_quality_gate_total[24h])",
        "legendFormat": "{{status}}",
        "datasource": "Prometheus"
      }]
    },
    {
      "id": 6,
      "title": "Documentos ingestados por día",
      "type": "stat",
      "gridPos": {"h": 6, "w": 6, "x": 18, "y": 8},
      "targets": [{
        "expr": "increase(ia_ingest_total[24h])",
        "legendFormat": "{{tenant_id}}",
        "datasource": "Prometheus"
      }]
    },
    {
      "id": 7,
      "title": "HTTP — error rate (5xx)",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 14},
      "targets": [{
        "expr": "rate(http_requests_total{status=~\"5..\"}[5m]) * 60",
        "legendFormat": "{{handler}} {{status}}",
        "datasource": "Prometheus"
      }]
    },
    {
      "id": 8,
      "title": "Pipeline de ingesta — duración (ms)",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 14},
      "targets": [{
        "expr": "histogram_quantile(0.95, rate(ia_pipeline_duration_ms_bucket[5m]))",
        "legendFormat": "p95 {{tenant_id}}",
        "datasource": "Prometheus"
      }]
    },
    {
      "id": 9,
      "title": "Logs del backend",
      "type": "logs",
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 20},
      "targets": [{
        "expr": "{service=\"backend\"} |= ``",
        "legendFormat": "",
        "datasource": "Loki"
      }],
      "options": {"showTime": true, "sortOrder": "Descending"}
    }
  ],
  "schemaVersion": 38,
  "version": 1
}
